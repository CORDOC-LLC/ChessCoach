# Copy this file to `local.env` (gitignored) and fill in your own Apple
# Developer Team ID. `scripts/gen-project.sh` sources it before running
# XcodeGen, so project.yml never has to hardcode a personal Team ID.
#
#   cp local.env.example local.env
#
# Find your Team ID at https://developer.apple.com/account (Membership),
# or in Xcode: Settings > Accounts > your Apple ID > your team.

DEVELOPMENT_TEAM=YOUR_TEAM_ID

# Optional: only needed to build a TestFlight upload yourself. Must match
# chesscoach-gateway's CHESSCOACH_DEBUG_BYPASS_TOKEN. See BuildChannel.swift /
# ManagedCoachStore.swift for how this is used.
MANAGED_TESTFLIGHT_TOKEN=
